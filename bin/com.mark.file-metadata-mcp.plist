<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mark.file-metadata-mcp</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/mark/bin/run-file-metadata-mcp-launch</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/mark/.claude/logs/file-metadata-mcp.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mark/.claude/logs/file-metadata-mcp.err</string>
    <key>WorkingDirectory</key>
    <string>/Users/mark/src/file_metadata_and_embeddings</string>
</dict>
</plist>
