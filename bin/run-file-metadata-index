#!/usr/bin/env bash
# run-file-metadata-index — runs hourly via com.mark.file-metadata-index LaunchAgent.
# Scans directories for new/changed files → PostgreSQL file_metadata database.
# Lives in ~/bin/ (not ~/Documents/) so launchd can execute it without FDA.
# All paths are absolute so WorkingDirectory doesn't matter.

UV=/Users/mark/.local/bin/uv
PROJECT=/Users/mark/Documents/src/file_metadata_and_embeddings
SCRIPT="$PROJECT/file_metadata_content.py"
LSA_BUILD="$PROJECT/build_lsa_index.py"
GEMINI_EXTRACT="$PROJECT/gemini_log_extractor.py"
WORKERS=${WORKERS:-4}

EXTENSIONS=".md,.txt,.rst,.py,.go,.rs,.ts,.js,.sh,.bash,.toml,.yaml,.yml,.jsonl"
DENYLIST="linux-6.*,linux-6*,kernel-*,llvm-project*,chromium*,gecko-dev*,webkit*,vuln_source_data,vuln_source_data-*,dsl.ai,linux-kernel,linux-kernel-*"

run() {
    "$UV" run --project "$PROJECT" \
        python3 "$SCRIPT" \
        --skip-embeddings \
        --extensions "$EXTENSIONS" \
        --denylist "$DENYLIST" \
        --workers "$WORKERS" \
        "$@"
}

run /Users/mark/Documents/src
run /Users/mark/Documents/writing
# ~/.claude is hidden — allowlist overrides the hidden-path check
run --allowlist /Users/mark/.claude /Users/mark/.claude
# ~/.gemini/extracted is hidden — extract session JSONs to .md first, then scan
"$UV" run --project "$PROJECT" python3 "$GEMINI_EXTRACT"
run --allowlist /Users/mark/.gemini/extracted /Users/mark/.gemini/extracted

# Encode new chunks (lsa_vec IS NULL) using the existing LSA model. Does not refit.
"$UV" run --project "$PROJECT" python3 "$LSA_BUILD" --incremental
